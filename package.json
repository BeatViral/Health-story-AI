    "build": "npm run build:web && npm run build:extension"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.35",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "typescript": "^5.7.0"
  }
}
